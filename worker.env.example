FLOW_API_BASE_URL=https://flow-image-api.chatapi.fun
FLOW_WORKER_TOKEN=replace-with-the-private-worker-token
FLOW_WORKER_ID=windows-flow-worker
FLOW_GFLOW_RUNNER_PS1=D:\workspace\bin\gflow-run.ps1
FLOW_GFLOW_PROFILE=your-gflow-profile
FLOW_GFLOW_OUTPUT_DIR=D:\workspace\output\flow-image-api
# Optional. When omitted, the Worker reads the operating system proxy.
FLOW_HTTP_PROXY=
FLOW_WORKER_POLL_SECONDS=3
FLOW_GENERATION_TIMEOUT_SECONDS=900
FLOW_KEEP_LOCAL_OUTPUTS=true
